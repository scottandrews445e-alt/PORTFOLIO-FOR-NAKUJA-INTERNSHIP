#!/usr/bin/env python3
"""
Telemetry Data Processor
Processes rocket sensor data and generates reports
"""

import csv
import json
from datetime import datetime
import matplotlib.pyplot as plt
import numpy as np

class TelemetryProcessor:
    def __init__(self, csv_file):
        self.data = self.load_data(csv_file)
    
    def load_data(self, csv_file):
        """Load telemetry data from CSV"""
        data = {
            'time': [],
            'pressure': [],
            'altitude': [],
            'temperature': []
        }
        
        try:
            with open(csv_file, 'r') as f:
                reader = csv.reader(f)
                for row in reader:
                    data['time'].append(float(row[0]))
                    data['pressure'].append(float(row[1]))
                    data['altitude'].append(float(row[2]))
                    data['temperature'].append(float(row[3]))
        except FileNotFoundError:
            print(f"Error: {csv_file} not found")
            return None
        
        return data
    
    def analyze(self):
        """Perform statistical analysis"""
        if not self.data:
            return None
        
        analysis = {
            'max_altitude': max(self.data['altitude']),
            'max_pressure': max(self.data['pressure']),
            'avg_temperature': np.mean(self.data['temperature']),
            'flight_duration': self.data['time'][-1] - self.data['time'][0]
        }
        return analysis
    
    def generate_report(self, output_file='report.json'):
        """Generate analysis report"""
        analysis = self.analyze()
        
        report = {
            'timestamp': datetime.now().isoformat(),
            'analysis': analysis,
            'statistics': {
                'samples': len(self.data['time']),
                'duration_ms': self.data['time'][-1]
            }
        }
        
        with open(output_file, 'w') as f:
            json.dump(report, f, indent=2)
        
        print(f"Report generated: {output_file}")
        return report
    
    def plot_data(self, output_file='telemetry_plot.png'):
        """Visualize telemetry data"""
        fig, axes = plt.subplots(3, 1, figsize=(12, 8))
        
        # Pressure plot
        axes[0].plot(self.data['time'], self.data['pressure'], 'b-')
        axes[0].set_ylabel('Pressure (hPa)')
        axes[0].set_title('Rocket Telemetry Data')
        axes[0].grid(True)
        
        # Altitude plot
        axes[1].plot(self.data['time'], self.data['altitude'], 'g-')
        axes[1].set_ylabel('Altitude (m)')
        axes[1].grid(True)
        
        # Temperature plot
        axes[2].plot(self.data['time'], self.data['temperature'], 'r-')
        axes[2].set_ylabel('Temperature (°C)')
        axes[2].set_xlabel('Time (ms)')
        axes[2].grid(True)
        
        plt.tight_layout()
        plt.savefig(output_file, dpi=300)
        print(f"Plot saved: {output_file}")

if __name__ == "__main__":
    processor = TelemetryProcessor('data.csv')
    processor.generate_report()
    processor.plot_data()
